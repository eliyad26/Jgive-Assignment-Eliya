<% content_for :title, @campaign.title %>

<%# ── Hero media — full-width thumbnail, click to play inline ───────────── %>
<% yt_id = @campaign.video_url.present? \
     ? @campaign.video_url.match(%r{(?:v=|youtu\.be/)([^&\n?#]+)})&.[](1) \
     : nil %>
<% if yt_id %>
  <% embed_url = "https://www.youtube.com/embed/#{yt_id}" %>
  <%# Container: fixed height captured by JS before iframe swap %>
  <div id="hero-wrap"
       class="relative w-full bg-black overflow-hidden cursor-pointer select-none"
       onclick="playHeroVideo(this,'<%= j embed_url %>')">
    <%# Thumbnail — maxresdefault with hqdefault fallback %>
    <img src="https://img.youtube.com/vi/<%= yt_id %>/maxresdefault.jpg"
         onerror="this.src='https://img.youtube.com/vi/<%= yt_id %>/hqdefault.jpg'"
         alt="<%= @campaign.title %>"
         class="w-full block"
         style="max-height:420px;object-fit:cover">
    <%# Bottom gradient so title is readable %>
    <div class="absolute inset-0 pointer-events-none"
         style="background:linear-gradient(to top,rgba(0,0,0,0.65) 0%,transparent 55%)"></div>
    <%# Title overlay %>
    <div class="absolute bottom-0 inset-x-0 p-6 md:p-10 pointer-events-none">
      <p class="text-white font-black text-2xl md:text-5xl drop-shadow-lg leading-tight">
        <%= @campaign.title %>
      </p>
    </div>
    <%# Play button %>
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
      <div class="w-16 h-16 md:w-20 md:h-20 rounded-full flex items-center justify-center shadow-2xl"
           style="background:rgba(255,255,255,0.85)">
        <svg class="w-8 h-8 md:w-10 md:h-10" fill="#1a1a1a" viewBox="0 0 24 24"
             style="margin-inline-start:4px">
          <path d="M8 5v14l11-7z"/>
        </svg>
      </div>
    </div>
  </div>
  <script>
  function playHeroVideo(container, embedUrl) {
    var h = container.offsetHeight;
    container.style.height = h + 'px';
    container.style.cursor = 'default';
    container.onclick = null;
    container.innerHTML =
      '<iframe src="' + embedUrl + '?autoplay=1&rel=0&modestbranding=1"' +
      ' allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture"' +
      ' allowfullscreen style="width:100%;height:100%;border:0;display:block"></iframe>';
  }
  </script>
<% elsif @campaign.cover_image_url.present? %>
  <div class="relative w-full bg-black overflow-hidden">
    <img src="<%= @campaign.cover_image_url %>"
         alt="<%= @campaign.title %>"
         class="w-full block" style="max-height:420px;object-fit:cover">
    <div class="absolute inset-0 pointer-events-none"
         style="background:linear-gradient(to top,rgba(0,0,0,0.65) 0%,transparent 55%)"></div>
    <div class="absolute bottom-0 inset-x-0 p-6 md:p-10 pointer-events-none">
      <p class="text-white font-black text-2xl md:text-5xl drop-shadow-lg leading-tight">
        <%= @campaign.title %>
      </p>
    </div>
  </div>
<% end %>

<%# ── Campaign stats strip ───────────────────────────────────────────────── %>
<section class="bg-white border-b border-gray-200 py-8">
  <div class="max-w-6xl mx-auto px-4">

      <%# ── Summary panel ──────────────────────────────────────────────── %>
      <div class="flex flex-col">

        <%# Title & slogan %>
        <h1 class="text-3xl md:text-4xl font-black text-gray-900 leading-tight mb-2">
          <%= @campaign.title %>
        </h1>
        <% if @campaign.slogan.present? %>
          <p class="text-lg text-gray-500 font-medium mb-6"><%= @campaign.slogan %></p>
        <% end %>

        <%# Amount raised (hero number) %>
        <div class="mb-1">
          <span class="text-5xl font-black" style="color:#008043">
            <%= format_ils_tag(@campaign.total_raised_cents) %>
          </span>
        </div>
        <p class="text-sm text-gray-500 mb-1">
          <span class="lang-he">מתוך יעד של</span><span class="lang-en">of a goal of</span>
          <span class="font-semibold text-gray-700"><%= format_ils_tag(@campaign.goal_amount_cents) %></span>
        </p>
        <% if @campaign.has_bonus_goal? %>
          <p class="text-xs text-gray-400 mb-3">
            <span class="lang-he">יעד בונוס:</span><span class="lang-en">Bonus goal:</span>
            <span class="font-semibold"><%= format_ils_tag(@campaign.bonus_goal_amount_cents) %></span>
          </p>
        <% end %>

        <%# Donor count %>
        <p class="text-sm text-gray-600 mb-5">
          <span class="font-bold text-gray-800"><%= number_with_delimiter(@campaign.donor_count) %></span>
          <span class="lang-he">תורמים</span><span class="lang-en">donors</span>
        </p>

        <%# ── Progress bar ──────────────────────────────────────────────────── %>
        <% segs = progress_bar_segments(@campaign) %>
        <div class="mb-4">
          <%# Outer wrapper is relative so the heart SVG can escape overflow-hidden %>
          <div class="relative" dir="ltr">
            <div class="relative h-5 rounded-full bg-gray-200 overflow-hidden">
              <% if segs[:type] == :dual %>
                <%# Green zone from right (main goal threshold) %>
                <div class="absolute inset-y-0 right-0"
                     style="width:<%= segs[:green_right] %>%; background-color:#008043"></div>
                <%# Purple fill from left (raised progress — drawn on top of green) %>
                <div class="absolute inset-y-0 left-0 rounded-l-full"
                     style="width:<%= segs[:purple] %>%; background-color:#d426ff"></div>
              <% else %>
                <%# Single goal: simple green fill from left %>
                <div class="absolute inset-y-0 left-0 rounded-l-full"
                     style="width:<%= segs[:fill] %>%; background-color:#008043"></div>
              <% end %>
            </div>
            <%# Orange heart at tip of fill — sits outside overflow-hidden so it floats %>
            <% heart_pos = segs[:type] == :dual ? segs[:heart_left] : segs[:fill] %>
            <% if heart_pos > 0 %>
              <div class="absolute inset-y-0 z-10 flex items-center pointer-events-none"
                   style="left:<%= heart_pos %>%; transform:translateX(-50%)">
                <svg class="w-5 h-5 drop-shadow" viewBox="0 0 20 20" fill="#f59e0b">
                  <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/>
                </svg>
              </div>
            <% end %>
          </div>

          <%# Labels below bar %>
          <% if segs[:type] == :dual %>
            <div class="flex items-start justify-between mt-2 text-xs">
              <%# First → RIGHT in RTL: donor count %>
              <div style="color:#008043">
                <span class="font-bold"><%= number_with_delimiter(@campaign.donor_count) %></span>
                <span class="font-normal text-gray-400"> :<span class="lang-he">תורמים</span><span class="lang-en">donors</span></span>
              </div>
              <%# Center: main goal %>
              <div class="text-center" style="color:#008043">
                <span class="font-bold"><%= format_ils_tag(@campaign.goal_amount_cents) %></span>
                <span class="font-normal text-gray-400"> :<span class="lang-he">יעד</span><span class="lang-en">goal</span></span>
              </div>
              <%# Last → LEFT in RTL: bonus goal %>
              <div style="color:#d426ff">
                <span class="font-bold"><%= format_ils_tag(@campaign.bonus_goal_amount_cents) %></span>
                <span class="font-normal opacity-70"> :<span class="lang-he">יעד בונוס</span><span class="lang-en">bonus</span></span>
              </div>
            </div>
          <% else %>
            <div class="flex items-center mt-1.5 text-xs font-medium">
              <span style="color:#008043"><%= @campaign.main_progress_percentage %>%</span>
            </div>
          <% end %>
        </div>

        <%# ── CTA button — opens donation modal ──────────────────────────── %>
        <button type="button" onclick="openDonationModal()"
                class="mt-2 block w-full text-center text-white font-black text-xl
                       py-4 px-6 rounded-2xl shadow-lg transition-colors duration-200 cursor-pointer"
                style="background-color:#d426ff"
                onmouseover="this.style.backgroundColor='#b800e0'"
                onmouseout="this.style.backgroundColor='#d426ff'">
          <span class="lang-he">תרום עכשיו</span><span class="lang-en">Donate Now</span>
        </button>

      </div><%# /summary panel %>
  </div><%# /container %>
</section>

<%# ── Two-column layout: sidebar (form) + main content (tabs) ─────────────── %>
<div class="max-w-6xl mx-auto px-4 py-8">
  <div class="flex flex-col lg:flex-row items-start gap-8">

    <%# ── Main content: tabs + tab panels ───────────────────────────────────── %>
    <div class="flex-1 min-w-0">

      <%# Tab bar %>
      <div class="flex border-b border-gray-200 mb-8 text-sm font-semibold -mb-px">

        <% tab_class = ->(name) {
          base = "pb-3 px-5 border-b-2 transition-colors duration-150 "
          @active_tab == name \
            ? base + "border-teal-500 text-teal-600"
            : base + "border-transparent text-gray-400 hover:text-gray-700"
        } %>

        <%= link_to campaign_path(@campaign, tab: "story"),
              class: tab_class.call("story") do %>
          <span class="lang-he">סיפור</span><span class="lang-en">Story</span>
        <% end %>

        <%= link_to campaign_path(@campaign, tab: "updates"),
              class: tab_class.call("updates") do %>
          <span class="lang-he">עדכונים</span><span class="lang-en">Updates</span>
        <% end %>

        <%= link_to campaign_path(@campaign, tab: "donors"),
              class: tab_class.call("donors") do %>
          <span class="lang-he">תורמים</span><span class="lang-en">Donors</span>
          <span class="mr-1 text-xs font-normal text-gray-400">
            (<%= number_with_delimiter(@campaign.donor_count) %>)
          </span>
        <% end %>

      </div>

      <%# ── Story tab ──────────────────────────────────────────────────────── %>
      <% if @active_tab == "story" %>
        <% if @campaign.story.present? %>
          <div class="prose max-w-none text-gray-700 leading-relaxed whitespace-pre-line">
            <%= @campaign.story %>
          </div>
        <% else %>
          <%= render "shared/empty_state",
                title:       "הסיפור עדיין לא נכתב",
                title_en:    "Story not yet written",
                subtitle:    "מארגן הקמפיין יוסיף בקרוב.",
                subtitle_en: "The campaign organizer will add this soon." %>
        <% end %>

      <%# ── Updates tab ──────────────────────────────────────────────────── %>
      <% elsif @active_tab == "updates" %>
        <%= render "shared/empty_state",
              icon:        :bell,
              title:       "אין עדכונים עדיין",
              title_en:    "No updates yet",
              subtitle:    "מארגן הקמפיין יפרסם עדכונים כאן כשיהיו חדשות.",
              subtitle_en: "The campaign organizer will post updates here when there is news." %>

      <%# ── Donors tab ───────────────────────────────────────────────────── %>
      <% elsif @active_tab == "donors" %>
        <div id="donors-list">
        <% donors = @campaign.display_donations %>
        <% if donors.empty? %>
          <%= render "shared/empty_state",
                icon:        :users,
                title:       "היו הראשונים לתרום!",
                title_en:    "Be the first to donate!",
                subtitle:    "רשימת התורמים תופיע כאן.",
                subtitle_en: "The donor list will appear here." %>
        <% else %>
          <div class="space-y-3">
            <% donors.each do |donation| %>
              <div class="bg-white rounded-xl border border-gray-100 shadow-sm px-5 py-4">

                <div class="flex items-center gap-4">

                  <%# Avatar %>
                  <div class="w-10 h-10 rounded-full flex-shrink-0 flex items-center justify-center
                               <%= donation.anonymous? ? 'bg-gray-100' : 'bg-teal-50' %>">
                    <% if donation.anonymous? %>
                      <svg class="w-5 h-5 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd"
                              d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"
                              clip-rule="evenodd"/>
                      </svg>
                    <% else %>
                      <span class="text-teal-600 font-black text-sm leading-none">
                        <%= donation.displayed_name.chars.first %>
                      </span>
                    <% end %>
                  </div>

                  <%# Name + time %>
                  <div class="flex-1 min-w-0">
                    <p class="font-semibold text-gray-900 text-sm truncate">
                      <%= donation.displayed_name %>
                      <% if donation.frequency == "monthly" %>
                        <span class="text-xs font-normal text-teal-500 mr-1">
                          <span class="lang-he">• חודשי</span><span class="lang-en">• Monthly</span>
                        </span>
                      <% end %>
                    </p>
                    <p class="text-xs text-gray-400 mt-0.5">
                      <span class="lang-he">לפני <%= time_ago_in_words(donation.created_at) %></span>
                      <span class="lang-en"><%= I18n.with_locale(:en) { time_ago_in_words(donation.created_at) } %> ago</span>
                    </p>
                  </div>

                  <%# Amount + badge %>
                  <div class="flex flex-col items-end gap-1 flex-shrink-0">
                    <span class="font-black text-base" style="color:#008043">
                      <%= format_ils_tag(donation.amount_cents) %>
                    </span>
                    <% if donation.pending? %>
                      <span class="text-[10px] font-semibold bg-amber-50 text-amber-600
                                   border border-amber-200 rounded-full px-2 py-0.5 leading-none">
                        <span class="lang-he">ממתין לאישור</span><span class="lang-en">Pending</span>
                      </span>
                    <% end %>
                  </div>

                </div>

                <% if donation.dedication.present? %>
                  <div class="mt-3 me-14 pe-3 border-e-2 border-teal-200">
                    <p class="text-sm text-gray-500 italic">"<%= donation.dedication %>"</p>
                  </div>
                <% end %>

              </div>
            <% end %>
          </div>
        <% end %>
        </div><%# /donors-list %>
      <% end %>

    </div><%# /main content %>

  </div><%# /two-column flex %>
</div>

<%# ── Donation modal ─────────────────────────────────────────────────────── %>
<div id="donation-modal"
     class="fixed inset-0 z-50 flex items-center justify-center p-4 hidden"
     role="dialog" aria-modal="true">
  <%# Backdrop %>
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"
       onclick="closeDonationModal()"></div>
  <%# Panel %>
  <div class="relative z-10 w-full max-w-md max-h-[90vh] overflow-y-auto rounded-2xl shadow-2xl bg-white"
       style="border:2px solid #d426ff;scrollbar-width:none;-ms-overflow-style:none">
    <%# Close button %>
    <button type="button" onclick="closeDonationModal()"
            class="absolute top-3 end-3 z-20 w-8 h-8 rounded-full flex items-center justify-center
                   hover:bg-gray-100 text-xl leading-none cursor-pointer font-bold"
            style="color:#d426ff">
      ×
    </button>
    <%= render "donations/form", campaign: @campaign, donation: @donation %>
  </div>
</div>

<script>
(function () {
  function openDonationModal() {
    document.getElementById('donation-modal').classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }
  function closeDonationModal() {
    document.getElementById('donation-modal').classList.add('hidden');
    document.body.style.overflow = '';
  }
  window.openDonationModal  = openDonationModal;
  window.closeDonationModal = closeDonationModal;

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeDonationModal();
  });

  <% if @donation.errors.any? %>
  openDonationModal();
  <% end %>
}());
</script>
