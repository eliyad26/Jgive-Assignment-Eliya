<%# Reusable empty-state component.
    Locals: title (string, required), subtitle (string, optional), icon (symbol :box|:bell|:users, optional) %>
<% icon  = local_assigns.fetch(:icon, :box) %>
<% sub   = local_assigns.fetch(:subtitle, nil) %>

<div class="flex flex-col items-center justify-center py-20 text-center">

  <%# Icon %>
  <div class="mb-5 w-16 h-16 rounded-full bg-gray-100 flex items-center justify-center">
    <% if icon == :bell %>
      <svg class="w-8 h-8 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6 6 0
                 00-9.33-5.003 6.03 6.03 0 00-.67.52M9 17H4l1.405-1.405A2.032
                 2.032 0 006 14.158V11c0-.35.04-.694.114-1.027M15 17a3 3 0
                 01-6 0m6 0H9"/>
      </svg>
    <% elsif icon == :users %>
      <svg class="w-8 h-8 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M17 20h5v-2a4 4 0 00-5.196-3.796M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7
                 20H2v-2a4 4 0 015.196-3.796M7 20v-2c0-.656.126-1.283.356-1.857m0
                 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2
                 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
      </svg>
    <% else %>
      <%# default: box %>
      <svg class="w-8 h-8 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M20 7l-8-4-8 4m16 0v10l-8 4m0-10L4 7m8 4v10"/>
      </svg>
    <% end %>
  </div>

  <p class="text-gray-500 font-semibold text-base mb-1"><%= title %></p>
  <% if sub.present? %>
    <p class="text-sm text-gray-400 max-w-xs"><%= sub %></p>
  <% end %>

</div>
