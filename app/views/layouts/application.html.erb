<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= content_for?(:title) ? yield(:title) : "JGive" %></title>

  <%# Heebo — designed for Hebrew, weights 300–900 %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;700;800;900&display=swap" rel="stylesheet">

  <%# Tailwind CDN — replaced by tailwindcss-rails gem before production %>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { sans: ['Heebo', 'sans-serif'] },
          colors: {
            brand: {
              teal:   '#0da89e',
              tealDk: '#0a8f86',
              orange: '#ff6b35',
              orangeHover: '#e85e2a',
            }
          }
        }
      }
    }
  </script>
  <style>
    body { font-family: 'Heebo', sans-serif; }
    /* Smooth scroll for "donate now" anchor */
    html { scroll-behavior: smooth; }
  </style>
</head>
<body class="bg-gray-50 text-gray-900 antialiased">

  <%# ── Minimal site header ──────────────────────────────────── %>
  <header class="bg-white border-b border-gray-200 sticky top-0 z-30 shadow-sm">
    <div class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
      <span class="text-2xl font-black tracking-tight" style="color:#0da89e">jgive</span>
      <nav class="text-sm text-gray-500 flex gap-6">
        <a href="#" class="hover:text-gray-800 transition-colors">צור קשר</a>
        <a href="#" class="hover:text-gray-800 transition-colors">עמדות</a>
      </nav>
    </div>
  </header>

  <main>
    <%# Flash messages ── green banner for notice, red for alert; auto-dismissed after 5 s %>
    <% flash.each_with_index do |(type, msg), i| %>
      <% is_notice = type.to_s == "notice" %>
      <% flash_class = is_notice \
           ? "bg-green-50 text-green-800 border-b border-green-200" \
           : "bg-red-50 text-red-800 border-b border-red-200" %>
      <div id="flash-<%= i %>" role="<%= is_notice ? 'status' : 'alert' %>"
           class="px-4 py-3 text-sm font-medium text-center transition-opacity duration-500 <%= flash_class %>">
        <%= msg %>
      </div>
    <% end %>

    <%= yield %>
  </main>

  <%# Auto-dismiss all flash banners after 5 s %>
  <% if flash.any? %>
    <script>
      setTimeout(function () {
        document.querySelectorAll('[id^="flash-"]').forEach(function (el) {
          el.style.opacity = '0';
          setTimeout(function () { el.remove(); }, 500);
        });
      }, 5000);
    </script>
  <% end %>

</body>
</html>
